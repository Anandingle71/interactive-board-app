<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.BoardAnnotate" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!-- Toolbar item styles -->
    <style name="Tool">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_marginHorizontal">2dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Swatch">
        <item name="android:layout_width">36dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginHorizontal">4dp</item>
    </style>

    <style name="Sep">
        <item name="android:layout_width">1dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_marginHorizontal">8dp</item>
        <item name="android:background">#33000000</item>
    </style>

</resources>
